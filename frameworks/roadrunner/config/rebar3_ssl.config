%% rebar3 BEAM TLS workaround for OTP 29 RC3 + Fastly hex.pm fingerprint
%% filter. Loaded by the Dockerfile build stage via
%% ERL_FLAGS="-config /src/config/rebar3_ssl" so it only affects rebar3
%% during dep fetch, not the application's own ssl listener.
[
    {ssl, [
        {cacertfile, "/etc/ssl/certs/ca-certificates.crt"},
        {middlebox_comp_mode, false},
        {versions, ['tlsv1.2']}
    ]}
].
